<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2010/07/nuspec.xsd">
	<!--https://docs.microsoft.com/en-us/nuget/reference/nuspec-->
	<metadata>
		<id>TqkLibrary.FFmpeg.Tools</id>
		<version>$version$</version>
		<description>FFmpeg Tools (ffmpeg, ffplay, ffprobe) $os$ $arch$ ($license$)</description>
		<authors>tqk2811</authors>
		<readme>docs\README.md</readme>
		<projectUrl>https://github.com/tqk2811/TqkLibrary.FFmpegBuild</projectUrl>
		<repository type="git" url="https://github.com/tqk2811/TqkLibrary.FFmpegBuild.git"/>
		<license type="expression">$license$</license>
		<tags>native ffmpeg</tags>
		<dependencies>
			<dependency id="TqkLibrary.FFmpeg.Native" version="[$version$,$version$]"/>
		</dependencies>
		<contentFiles>
			<files include="**/*.*" copyToOutput="true" buildAction="None"/>
		</contentFiles>
	</metadata>

	<files>
		<file src="README.md" target="docs\" />
		<file src="LICENSE.txt" target="docs\" />
		<file src="$idTools$.props" target="build\" />
		<file src="$idTools$.targets" target="build\" />

		<file src="$path$\ffmpeg*" target="runtimes\$os$-$arch$\native\" />
		<file src="$path$\ffplay*" target="runtimes\$os$-$arch$\native\" />
		<file src="$path$\ffprobe*" target="runtimes\$os$-$arch$\native\" />
	</files>
</package>